# Cloudflare Workers (Pages Functions) 配置
# 用于自定义 _headers 和重定向规则

# 允许 iframe 跨域嵌入（ui.aibms.net 需要访问 AIBMSBridge）
[[headers]]
  for = "/*"
  [headers.values]
    # 允许被 iframe 嵌入（同源或指定域名）
    X-Frame-Options = "SAMEORIGIN"
    # CSP 允许 iframe 加载 ui.aibms.net
    Content-Security-Policy = "frame-src https://ui.aibms.net https://*.aibms.net; default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;"
    # 允许 Web Bluetooth 和 Web Serial
    Permissions-Policy = "bluetooth=*, serial=*"
    Cross-Origin-Opener-Policy = "same-origin"
    Cross-Origin-Embedder-Policy = "require-corp"

# 静态资源缓存
[[headers]]
  for = "/assets/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

# SPA 路由回退 - 所有路由返回 index.html
[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
