/*
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: frame-src https://ui.aibms.net https://*.aibms.net; default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline';
  Permissions-Policy: bluetooth=*, serial=*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/assets/*
  Cache-Control: public, max-age=31536000, immutable
